#!/usr/bin/env sh
set -eu

# Allow emergency bypass:
#   CODEWARP_SKIP_HOOK_FMT=1 git commit -m "..."
if [ "${CODEWARP_SKIP_HOOK_FMT:-}" = "1" ]; then
  echo "[pre-commit] Skipping fmt check because CODEWARP_SKIP_HOOK_FMT=1"
  exit 0
fi

echo "[pre-commit] Running cargo fmt -- --check..."
cargo fmt -- --check
echo "[pre-commit] fmt check passed."
